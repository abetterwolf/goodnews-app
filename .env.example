# ─────────────────────────────────────────────
# GoodNews App — Environment Variables Example
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Taskade API ───────────────────────────────
# Your Taskade space ID (found in your workspace URL)
VITE_TASKADE_SPACE_ID=your_space_id_here

# Your Taskade API base URL
VITE_TASKADE_API_URL=https://www.taskade.com/api/v1

# ── Taskade Projects ──────────────────────────
# Project ID for storing shared verses / share logs
VITE_VERSES_PROJECT_ID=your_verses_project_id_here

# Project ID for user prayer / engagement tracking
VITE_ENGAGEMENT_PROJECT_ID=your_engagement_project_id_here

# ── Taskade Agent ─────────────────────────────
# Public Agent ID for the in-app AI assistant
VITE_AGENT_ID=your_agent_id_here

# ── Bible API ─────────────────────────────────
# Free Bible API base URL (no key required for api.bible or scripture.api.bible)
VITE_BIBLE_API_URL=https://bible-api.com

# Optional: scripture.api.bible key if you upgrade
# VITE_BIBLE_API_KEY=your_api_key_here

# ── App Config ────────────────────────────────
# Base URL of your deployed app (used for generating share links)
VITE_APP_URL=https://your-app.vercel.app

# App display name
VITE_APP_NAME=GoodNews

# ── Feature Flags ─────────────────────────────
# Enable or disable push notifications (true/false)
VITE_ENABLE_PUSH_NOTIFICATIONS=false

# Enable or disable daily verse scheduling
VITE_ENABLE_DAILY_VERSE=true

# ── Analytics (optional) ──────────────────────
# Plausible or simple analytics domain (optional, leave blank to disable)
# VITE_ANALYTICS_DOMAIN=your-app.vercel.app

